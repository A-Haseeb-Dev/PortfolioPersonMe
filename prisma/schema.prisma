generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  emailVerified DateTime?
  image        String?
  password     String
  role         String    @default("EDITOR")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  blogs        Blog[]
  downloads    Download[]

  @@index([role])
  @@index([deletedAt])
  @@index([createdAt])
}

model Project {
  id              String         @id @default(cuid())
  title           String
  slug            String         @unique
  description     String
  problem         String?
  solution        String?
  architecture    String?
  features        Json?
  githubUrl       String?
  liveUrl         String?
  videoDemo       String?
  results         String?
  lessonsLearned  String?
  published       Boolean        @default(false)
  featured        Boolean        @default(false)
  coverImage      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  images          ProjectImage[]
  technologies    ProjectTechnology[]
  technologyExperiences TechnologyExperience[]

  @@index([slug])
  @@index([published])
  @@index([featured])
  @@index([createdAt])
  @@index([deletedAt])
}

model ProjectImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  projectId String

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model TechnologyCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  icon        String?
  color       String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  technologies Technology[]

  @@index([slug])
  @@index([order])
}

model Technology {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  description      String?
  icon             String?
  color            String?
  proficiency      Int?
  experienceLevel  String           @default("INTERMEDIATE")
  yearsExperience  Float            @default(0)
  categoryId       String
  projectsUsing    Json?
  learningResources Json?
  relatedTechnologies Json?
  certificates     Json?
  useCases         Json?
  features         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  category             TechnologyCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  fromRelations        TechnologyRelation[]    @relation("FromTechnology")
  toRelations          TechnologyRelation[]    @relation("ToTechnology")
  experiences          TechnologyExperience[]
  projects             ProjectTechnology[]

  @@index([slug])
  @@index([categoryId])
  @@index([experienceLevel])
  @@index([deletedAt])
}

model TechnologyRelation {
  id               String   @id @default(cuid())
  fromTechnologyId String
  toTechnologyId   String
  relationType     String?
  createdAt        DateTime @default(now())

  fromTechnology   Technology @relation("FromTechnology", fields: [fromTechnologyId], references: [id], onDelete: Cascade)
  toTechnology     Technology @relation("ToTechnology", fields: [toTechnologyId], references: [id], onDelete: Cascade)

  @@index([fromTechnologyId])
  @@index([toTechnologyId])
}

model TechnologyExperience {
  id             String          @id @default(cuid())
  technologyId   String
  projectId      String?
  experienceLevel String          @default("INTERMEDIATE")
  notes          String?
  createdAt      DateTime        @default(now())

  technology     Technology      @relation(fields: [technologyId], references: [id], onDelete: Cascade)
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([technologyId])
  @@index([projectId])
}

model ProjectTechnology {
  id           String   @id @default(cuid())
  projectId    String
  technologyId String
  createdAt    DateTime @default(now())

  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([technologyId])
  @@unique([projectId, technologyId])
}

model Blog {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String
  excerpt     String?
  coverImage  String?
  readingTime Int?
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  seoTitle    String?
  seoDescription String?
  seoKeywords String?
  authorId    String
  categoryId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  author      User          @relation(fields: [authorId], references: [id], onDelete: Restrict)
  category    BlogCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  tags        BlogTags[]

  @@index([slug])
  @@index([published])
  @@index([featured])
  @@index([authorId])
  @@index([categoryId])
  @@index([createdAt])
  @@index([deletedAt])
}

model BlogCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  color       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  blogs       Blog[]

  @@index([slug])
}

model BlogTag {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())

  blogs     BlogTags[]

  @@index([slug])
}

model BlogTags {
  blogId String
  tagId  String

  blog   Blog    @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag    BlogTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
  @@index([tagId])
}

model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  icon        String?
  features    Json?
  price       Float?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([slug])
  @@index([published])
  @@index([deletedAt])
}

model Testimonial {
  id        String  @id @default(cuid())
  name      String
  title     String?
  company   String?
  avatar    String?
  content   String
  rating    Int     @default(5)
  featured  Boolean @default(false)
  order     Int     @default(0)
  createdAt DateTime @default(now())

  @@index([featured])
  @@index([order])
}

model Certificate {
  id           String    @id @default(cuid())
  title        String
  issuer       String
  date         DateTime?
  url          String?
  image        String?
  credentialId String?
  description  String?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  @@index([deletedAt])
}

model Achievement {
  id          String          @id @default(cuid())
  title       String
  description String?
  date        DateTime?
  type        String          @default("MILESTONE")
  issuer      String?
  featured    Boolean         @default(false)
  icon        String?
  url         String?
  createdAt   DateTime        @default(now())

  @@index([type])
  @@index([date])
  @@index([featured])
}

model Resource {
  id             String       @id @default(cuid())
  title          String
  slug           String       @unique
  description    String?
  type           String       @default("GUIDE")
  fileUrl        String?
  downloadCount  Int          @default(0)
  published      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  downloads      Download[]

  @@index([slug])
  @@index([type])
  @@index([published])
  @@index([deletedAt])
}

model StartupIdea {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  problem      String?
  solution     String?
  market       String?
  revenueModel String?
  status       String        @default("IDEA")
  published    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@index([slug])
  @@index([status])
  @@index([published])
  @@index([deletedAt])
}

model LearningJourney {
  id          String           @id @default(cuid())
  title       String
  description String?
  status      String           @default("CURRENT")
  category    String?
  resource    String?
  startDate   DateTime?
  endDate     DateTime?
  certificate String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  milestones  LearningMilestone[]

  @@index([status])
  @@index([category])
}

model LearningMilestone {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime?
  journeyId   String
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  journey     LearningJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@index([journeyId])
  @@index([completed])
}

model CaseStudy {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  client       String?
  industry     String?
  duration     String?
  role         String?
  team         String?
  problem      String?
  research     String?
  planning     String?
  design       String?
  architecture String?
  development  String?
  testing      String?
  deployment   String?
  results      String?
  technologies Json?
  coverImage   String?
  published    Boolean   @default(false)
  featured     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([slug])
  @@index([published])
  @@index([featured])
  @@index([createdAt])
  @@index([deletedAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  replied   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([read])
  @@index([replied])
  @@index([createdAt])
}

model Visitor {
  id        String   @id @default(cuid())
  ip        String?
  country   String?
  city      String?
  device    String?
  browser   String?
  referrer  String?
  page      String?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([ip])
  @@index([page])
  @@index([timestamp])
  @@index([country])
}

model Analytics {
  id             String   @id @default(cuid())
  date           DateTime
  page           String
  views          Int      @default(0)
  uniqueVisitors Int      @default(0)
  avgTimeOnPage  Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([date, page])
  @@index([date])
  @@index([page])
}

model Download {
  id         String    @id @default(cuid())
  resourceId String
  userId     String?
  ip         String?
  timestamp  DateTime  @default(now())
  createdAt  DateTime  @default(now())

  resource   Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([resourceId])
  @@index([userId])
  @@index([timestamp])
}

model SEO {
  id          String   @id @default(cuid())
  page        String   @unique
  title       String?
  description String?
  keywords    String?
  ogImage     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([page])
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model KnowledgeCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  icon        String?
  color       String?
  noteCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  notes       KnowledgeNote[]

  @@index([slug])
}

model KnowledgeNote {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  readingTime Int?
  categoryId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  category    KnowledgeCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  tags        KnowledgeNoteTag[]

  @@index([slug])
  @@index([categoryId])
  @@index([deletedAt])
}

model KnowledgeTag {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())

  notes     KnowledgeNoteTag[]

  @@index([slug])
}

model KnowledgeNoteTag {
  noteId String
  tagId  String

  note   KnowledgeNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    KnowledgeTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@index([tagId])
}

model GitHubRepo {
  id             String   @id @default(cuid())
  name           String
  description    String?
  stars          Int      @default(0)
  forks          Int      @default(0)
  issues         Int      @default(0)
  language       String?
  languageColor  String?
  url            String?
  topics         Json?
  updatedAt      DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([stars])
  @@index([updatedAt])
}

model GitHubProfile {
  id          String   @id @default(cuid())
  username    String   @unique
  name        String?
  avatar      String?
  bio         String?
  totalStars  Int      @default(0)
  totalForks  Int      @default(0)
  totalRepos  Int      @default(0)
  updatedAt   DateTime @default(now())

  @@index([username])
}
